{
  "manifest_version": 3,
  "name": "CogPrint — Quick Session Log",
  "version": "0.1.0",
  "description": "Log a CogPrint study session in one click, straight from your browser toolbar.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Log a CogPrint study session"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ]
}
