# ---------------------------------------------------------------------------
# CogPrint backend configuration. Copy to `.env` and edit. `.env` is gitignored.
# ---------------------------------------------------------------------------

# Database. SQLite by default (per-machine local file). For a deployed pilot,
# point this at Postgres, e.g. postgresql+psycopg://user:pass@host:5432/cogprint
DATABASE_URL=sqlite:///./cogprint.db

# Comma-separated list of allowed CORS origins (the deployed frontend URL).
# Leave unset for local dev (defaults to localhost:5173 + :4173).
# CORS_ORIGINS=https://research.cogprint.app,http://localhost:5173

# Optional API key. If set, sensitive researcher endpoints (bulk user list,
# CSV export) require an `X-API-Key: <this value>` header. If unset, those
# endpoints stay open — fine for local dev, NOT for a public deploy.
# COGPRINT_API_KEY=change-me-to-a-long-random-string

# Researcher dashboard password used by the frontend (Vite build-time var).
VITE_RESEARCHER_PASSWORD=cogprint2025

# Flashcard generation (Agent 4, the ONLY LLM-backed feature). Set this to
# enable POST /materials/{id}/questions. Without it, that endpoint returns 503
# and the rest of the app (all API-free) works normally. NEVER commit a real key.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: model used for flashcard generation. Defaults to claude-opus-4-8.
# Set to a cheaper model (e.g. claude-haiku-4-5) to cut cost.
# COGPRINT_QGEN_MODEL=claude-opus-4-8
